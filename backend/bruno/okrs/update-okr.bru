meta {
  name: Update OKR
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/api/v1/squads/{{squadId}}/okrs/{{okrId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "objective": "Improve platform reliability and performance",
    "status": "AtRisk"
  }
}
