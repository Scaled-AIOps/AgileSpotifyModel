meta {
  name: Add Key Result
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/v1/squads/{{squadId}}/okrs/{{okrId}}/keyresults
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "description": "Reduce p99 API latency",
    "metric": "latency_ms",
    "current": 450,
    "target": 200,
    "unit": "ms"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("krId", res.body.id);
  }
}
