meta {
  name: Create OKR
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/squads/{{squadId}}/okrs
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "objective": "Improve platform reliability",
    "quarter": "2026-Q2",
    "status": "OnTrack"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("okrId", res.body.id);
  }
}
