meta {
  name: Register (Admin only)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/auth/register
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "email": "newuser@example.com",
    "signet": "Signet123!",
    "name": "New User",
    "role": "Member"
  }
}
