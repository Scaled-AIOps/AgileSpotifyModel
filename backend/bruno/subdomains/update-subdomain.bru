meta {
  name: Update Subdomain
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/api/v1/subdomains/{{subdomainId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "description": "Updated description",
    "github": [
      { "url": "https://github.com/example/data-platform", "description": "Mono-repo" }
    ]
  }
}
