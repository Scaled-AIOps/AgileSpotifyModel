meta {
  name: Create Guild
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/guilds
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "GraphQL Guild",
    "description": "GraphQL practitioners across all tribes"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("guildId", res.body.id);
  }
}
