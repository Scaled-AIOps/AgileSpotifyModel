meta {
  name: Update Domain
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/api/v1/domains/{{domainId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "description": "Updated description",
    "confluence": [
      { "url": "https://confluence.example.com/display/PLAT", "description": "Domain home" }
    ]
  }
}
