meta {
  name: List Certificates
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/certificates
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

script:post-response {
  if (res.status === 200 && res.body.length > 0) {
    bru.setVar("certId", res.body[0].certId);
  }
}
