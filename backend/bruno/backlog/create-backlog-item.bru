meta {
  name: Create Backlog Item
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/squads/{{squadId}}/backlog
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "title": "Implement user authentication",
    "type": "Story",
    "status": "Backlog",
    "priority": 10,
    "storyPoints": 5
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("backlogItemId", res.body.id);
  }
}
