meta {
  name: Record Deploy
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/v1/apps/{{appId}}/prod/deploys
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "version": "1.2.3",
