meta {
  name: Create App
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/apps
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "appId": "my-service",
    "squadId": "{{squadId}}",
    "gitRepo": "https://github.com/example/my-service",
    "status": "active",
    "tags": { "team": "payments" },
    "platforms": {},
    "urls": {}
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("appId", res.body.appId);
  }
}
