# Copy this file to backend/config/.env and fill in real values

# ── Core ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3000
REDIS_URL=redis://localhost:6379
NODE_ENV=development

# URL the browser hits for API calls (used by Angular environment)
# CORS_ORIGIN is also used as the fallback FRONTEND_URL for OAuth redirects
CORS_ORIGIN=http://localhost:4200
FRONTEND_URL=http://localhost:4200
BACKEND_URL=http://localhost:3000

# ── Authentication ────────────────────────────────────────────────────────────

# Basic (username + password) login — disable to force SSO-only
AUTH_BASIC_ENABLED=true

# Jira / Atlassian OAuth 2.0 (3LO)
# Create an OAuth 2.0 app at https://developer.atlassian.com/console/myapps/
# Callback URL: ${BACKEND_URL}/api/v1/auth/jira/callback
JIRA_ENABLED=false
#JIRA_CLIENT_ID=
#JIRA_CLIENT_SECRET=

# Microsoft Azure AD / Entra ID OIDC
# Register an app at https://portal.azure.com → App registrations
# Callback URL: ${BACKEND_URL}/api/v1/auth/microsoft/callback
AD_ENABLED=false
#AZURE_CLIENT_ID=
#AZURE_TENANT_ID=common
#AZURE_CLIENT_SECRET=
