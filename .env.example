# Copy this file to backend/config/.env and fill in real values

# ── Core ──────────────────────────────────────────────────────────────────────
JWT_SIGNING_KEY=change-me-to-a-long-random-string
JWT_REFRESH_KEY=change-me-to-another-long-random-string

# Bearer token for automated ingest scripts (CI/CD, deploy hooks, fleet imports).
# Allowed routes: POST /apps, PATCH /apps/:appId, POST /apps/:appId/:env/deploys,
# PATCH /apps/:appId/:env/deploys. Required in production.
#INGEST_API_KEY=replace-with-a-long-opaque-token-min-24-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3000
REDIS_URL=redis://localhost:6379
# Local dev only — set to 'true' to use an in-memory ioredis-mock and skip the real Redis.
# Equivalent shortcut: REDIS_URL=mock. Production refuses both.
#REDIS_MOCK=true
# Namespace prepended to every Redis key — change only if you share one Redis
# instance and need a different prefix per deployment.
#REDIS_KEY_PREFIX=scaledaiops:
# Redis ACL username (optional, Redis 6+). Leave unset for the default user.
#REDIS_USERNAME=default
# Redis AUTH credential. Spliced into REDIS_URL at boot — keep REDIS_URL itself
# credential-free. Treat as a credential.
#REDIS_AUTH=replace-with-the-redis-auth-credential
NODE_ENV=development

# Browser-facing URL for OAuth redirects. CORS itself is handled by the
# platform (ingress / reverse proxy), not this app.
FRONTEND_URL=http://localhost:4200
BACKEND_URL=http://localhost:3000

# ── Authentication ────────────────────────────────────────────────────────────

# Basic (email + signet) login — disable to force SSO-only
AUTH_BASIC_ENABLED=true

# Jira / Atlassian OAuth 2.0 (3LO)
# Create an OAuth 2.0 app at https://developer.atlassian.com/console/myapps/
# Callback URL: ${BACKEND_URL}/api/v1/auth/jira/callback
# JIRA_CLIENT_KEY holds the OAuth confidential client credential the provider issues to your app.
JIRA_ENABLED=false
#JIRA_CLIENT_ID=
#JIRA_CLIENT_KEY=

# Microsoft Azure AD / Entra ID OIDC
# Register an app at https://portal.azure.com → App registrations
# Callback URL: ${BACKEND_URL}/api/v1/auth/microsoft/callback
# AZURE_CLIENT_KEY holds the confidential client credential value.
AD_ENABLED=false
#AZURE_CLIENT_ID=
#AZURE_TENANT_ID=common
#AZURE_CLIENT_KEY=
